    "@types/react-dom": "^19.0.3",
    "happy-dom": "^20.8.9",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^6.0.2",
    "vitest": "^3.0.2"
  },
  "packageManager": "npm@11.12.1"
